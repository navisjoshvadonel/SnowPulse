# ============================================
# SnowPulse Production Configuration Template
# ============================================
# Copy this file to .env and set actual values
# NEVER commit .env to version control
# ============================================

# --- Database ---
DB_NAME=snowpulse
DB_USER=postgres
DB_PASSWORD=change_me_in_production_to_secure_password
DB_PORT=5432

# --- Redis ---
REDIS_PASSWORD=change_me_in_production_to_secure_password
REDIS_PORT=6379

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production_to_secure_password
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Meilisearch (Full-text Search) ---
MEILI_ENV=production
MEILI_MASTER_KEY=change_me_in_production_to_secure_password
MEILI_HOST=http://meilisearch:7700
MEILI_PORT=7700

# --- FastAPI Backend ---
BACKEND_PORT=8000
JWT_SECRET_KEY=change_me_in_production_to_very_secure_secret_key_min_32_chars
LOG_LEVEL=info

# --- AI Services ---
GEMINI_API_KEY=your_google_generative_ai_key_here
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://backend:8000

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=change_me_in_production

# --- Caddy Reverse Proxy ---
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# --- Optional: Docker Registry (for CD/CD image pushes) ---
# DOCKER_REGISTRY_USERNAME=your_docker_username
# DOCKER_REGISTRY_PASSWORD=your_docker_password_or_token

# --- Optional: Secrets for CI/CD Workflows ---
# PRODUCTION_DB_PASSWORD=secure_production_db_password
# PRODUCTION_REDIS_PASSWORD=secure_production_redis_password
# PRODUCTION_MINIO_PASSWORD=secure_production_minio_password
# PRODUCTION_MEILI_KEY=secure_production_meili_key
